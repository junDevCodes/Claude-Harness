# ===========================================
# Environment
# ===========================================
ENVIRONMENT=development  # development | staging | production

# ===========================================
# Database — Write (Primary/Master)
# ===========================================
WRITE_DB_USER=postgres
WRITE_DB_PASSWORD=your_write_password
WRITE_DB_HOST=localhost
WRITE_DB_PORT=5432
WRITE_DB_NAME=myapp_db

# ===========================================
# Database — Read (Replica/Slave)
# For single-DB setups, use the same values as Write above
# ===========================================
READ_DB_USER=postgres
READ_DB_PASSWORD=your_read_password
READ_DB_HOST=localhost
READ_DB_PORT=5432
READ_DB_NAME=myapp_db

# Database SSL (auto-enabled in non-development unless explicitly set)
# DB_SSL_REQUIRED=false

# ===========================================
# JWT Authentication
# ===========================================
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ===========================================
# Mock Auth (Development Only)
# ===========================================
# MOCK_AUTH_ENABLED=true  # Uncomment for local dev without real tokens

# ===========================================
# AWS S3 (File Upload)
# ===========================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=your-bucket-name
