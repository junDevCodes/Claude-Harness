# ─── Spring Profiles ──────────────────────────────────────────────────────────
# 사용 가능한 값: local, prod
SPRING_PROFILES_ACTIVE=local

# ─── Server ───────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=base_db
DB_USER=postgres
DB_PASSWORD=postgres

# ─── JWT ──────────────────────────────────────────────────────────────────────
# 최소 256bit (32바이트) 이상, Base64 인코딩 필수
# 생성 예시: openssl rand -base64 64
JWT_SECRET=your-very-long-base64-encoded-secret-key-at-least-256-bits-long-replace-this

# Access Token 만료 시간 (초 단위, 기본값 900 = 15분)
JWT_ACCESS_TOKEN_EXPIRY=900

# Refresh Token 만료 시간 (초 단위, 기본값 604800 = 7일)
JWT_REFRESH_TOKEN_EXPIRY=604800

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=your-s3-bucket-name
