# ─── Server ───────────────────────────────────────────
NODE_ENV=development        # development | production
PORT=3000

# ─── Database ─────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/express_base?schema=public"

# ─── JWT ──────────────────────────────────────────────
# 최소 32자 랜덤 문자열 (openssl rand -hex 32)
JWT_ACCESS_SECRET=your-access-token-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars

# Access token 만료 (예: 15m, 1h, 7d)
JWT_ACCESS_EXPIRES_IN=15m
# Refresh token 만료 (예: 7d, 30d)
JWT_REFRESH_EXPIRES_IN=30d

# ─── AWS S3 ───────────────────────────────────────────
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=your-s3-bucket-name

# Presigned URL 유효 기간 (초)
AWS_S3_PRESIGNED_EXPIRES=3600

# ─── CORS ─────────────────────────────────────────────
# 허용할 Origin (쉼표 구분, 예: http://localhost:3000,https://example.com)
CORS_ORIGINS=http://localhost:3000
