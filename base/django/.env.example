# ---------------------------------------------------------------------------
# Environment Variables — Django 5 Base Project
# Copy this file to .env and fill in the values.
# ---------------------------------------------------------------------------

# Django
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-me-to-a-long-random-string-in-production

# Server
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# Option A: Full URL (preferred)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/django_dev

# Option B: Individual fields (used in docker-compose)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=django_dev
DB_USER=postgres
DB_PASSWORD=postgres

# ---------------------------------------------------------------------------
# AWS S3 (for file uploads)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET_NAME=your-s3-bucket-name
AWS_S3_REGION=ap-northeast-2

# ---------------------------------------------------------------------------
# Email (production SMTP — optional)
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your-sendgrid-api-key
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com
