{
    "version": "1.6",
    "description": "Skill activation triggers for Claude Code. Controls when skills automatically suggest or block actions.",
    "skills": {
        "skill-developer": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Meta-skill for creating and managing Claude Code skills",
            "promptTriggers": {
                "keywords": [
                    "skill system",
                    "create skill",
                    "add skill",
                    "skill triggers",
                    "skill rules",
                    "claude hook system",
                    "skill development",
                    "skill-rules.json"
                ],
                "intentPatterns": [
                    "(how do|how does|explain).*?skill",
                    "(create|add|modify|build).*?skill",
                    "skill.*?(work|trigger|activate|system)"
                ]
            }
        },
        "fastapi-backend-guidelines": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "FastAPI backend development patterns for Python async applications with SQLModel/SQLAlchemy, domain-driven design, and layered architecture",
            "promptTriggers": {
                "keywords": [
                    "fastapi",
                    "FastAPI",
                    "SQLModel",
                    "SQLAlchemy",
                    "pydantic",
                    "uvicorn",
                    "alembic"
                ],
                "intentPatterns": [
                    "(create|add|implement|build).*?(route|endpoint|API|router|service|repository)",
                    "(fix|handle|debug).*?(error|exception|backend)",
                    "(add|implement).*?(middleware|validation|error.*?handling)",
                    "(organize|structure|refactor).*?(backend|service|API|domain)",
                    "(how to|best practice).*?(fastapi|route|router|service|repository)",
                    "(database|orm|model).*?(query|create|update|delete)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "backend/**/*.py",
                    "base/fastapi/**/*.py"
                ],
                "pathExclusions": [
                    "**/__pycache__/**",
                    "**/*.pyc",
                    "**/test_*.py",
                    "**/*_test.py",
                    "**/conftest.py"
                ],
                "contentPatterns": [
                    "from fastapi import",
                    "@router\\.",
                    "async def",
                    "AsyncSession",
                    "SQLModel",
                    "class.*Service:",
                    "class.*Repository:"
                ]
            }
        },
        "nextjs-frontend-guidelines": {
            "type": "guardrail",
            "enforcement": "block",
            "priority": "high",
            "description": "Next.js 15/React 19/TypeScript best practices including App Router patterns, Server/Client Components, shadcn/ui, Tailwind CSS 4",
            "promptTriggers": {
                "keywords": [
                    "Next.js",
                    "nextjs",
                    "next.js",
                    "React",
                    "server component",
                    "client component",
                    "app router",
                    "use client",
                    "use server",
                    "shadcn",
                    "tailwind"
                ],
                "intentPatterns": [
                    "(create|add|make|build|update|modify|edit).*?(component|UI|page|modal|dialog|form)",
                    "(how to|best practice).*?(component|react|nextjs|next.js)",
                    "(style|design|layout).*?(component|UI)",
                    "(server|client).*?component",
                    "app router"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "frontend/src/**/*.tsx",
                    "frontend/src/**/*.ts",
                    "base/nextjs/src/**/*.tsx",
                    "base/nextjs/src/**/*.ts"
                ],
                "pathExclusions": [
                    "**/*.test.tsx",
                    "**/*.test.ts",
                    "**/*.spec.tsx",
                    "**/*.spec.ts",
                    "**/next.config.*",
                    "**/tsconfig.json"
                ],
                "contentPatterns": [
                    "'use client'",
                    "'use server'",
                    "export default async function",
                    "next/navigation",
                    "next/image"
                ]
            },
            "blockMessage": "⚠️ BLOCKED - Next.js Frontend Best Practices Required\n\n📋 REQUIRED ACTION:\n1. Use Skill tool: 'nextjs-frontend-guidelines'\n2. Review Next.js 15 App Router patterns (Server vs Client Components)\n3. Use proper shadcn/ui + Tailwind CSS 4 patterns\n4. Then retry this edit\n\nReason: Enforce Next.js 15 best practices\nFile: {file_path}\n\n💡 TIP: Add '// @skip-validation' comment to skip future checks",
            "skipConditions": {
                "sessionSkillUsed": true,
                "fileMarkers": [
                    "@skip-validation"
                ],
                "envOverride": "SKIP_FRONTEND_GUIDELINES"
            }
        },
        "pytest-backend-testing": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Comprehensive pytest testing guide for FastAPI backends. Covers unit testing, integration testing, async patterns, mocking, fixtures, coverage, and FastAPI-specific testing with TestClient.",
            "promptTriggers": {
                "keywords": [
                    "pytest",
                    "python test",
                    "unit test",
                    "integration test",
                    "test coverage",
                    "pytest mock",
                    "pytest fixture",
                    "MagicMock",
                    "AsyncMock",
                    "TestClient",
                    "async test"
                ],
                "intentPatterns": [
                    "(write|create|add|update|fix).*?test",
                    "(how to|how do I).*?test",
                    "test.*?(repository|service|route|endpoint|API)",
                    "(improve|increase|check).*?coverage",
                    "(mock|stub|fake).*?(database|session|repository|service)",
                    "failing test"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "backend/tests/**/*.py",
                    "base/fastapi/tests/**/*.py"
                ],
                "contentPatterns": [
                    "@pytest\\.mark",
                    "import pytest",
                    "def test_",
                    "async def test_",
                    "@pytest\\.fixture",
                    "AsyncMock",
                    "MagicMock",
                    "TestClient"
                ]
            }
        },
